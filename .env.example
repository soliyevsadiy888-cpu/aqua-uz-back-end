# ─── База данных PostgreSQL ───────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/aquauz

# ─── Telegram Bot ─────────────────────────────────────────────
BOT_TOKEN=1234567890:AAFabcdefghijklmnopqrstuvwxyz12345678
# Ваш Telegram user ID (получите у @userinfobot)
ADMIN_TELEGRAM_ID=123456789

# ─── JWT секрет (любая длинная случайная строка) ─────────────
JWT_SECRET=super_secret_key_change_this_in_production_min_32_chars

# ─── Настройки сервера ────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── URL фронтенда (для CORS) ─────────────────────────────────
FRONTEND_URL=https://aqua-uz-xxxxxxx.vercel.app

# ─── Webhook URL (Railway/Render/VPS домен) ───────────────────
# Telegram будет слать обновления на этот адрес
WEBHOOK_URL=https://aqua-uz-backend.up.railway.app

# ─── Eskiz.uz SMS-шлюз ───────────────────────────────────────
# Регистрация: https://eskiz.uz
# Если оставить пустым — SMS-коды работают в DEV-режиме:
# код возвращается прямо в ответе API (_dev_code), реальные SMS не шлются.
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your_eskiz_password
# Имя отправителя (латиница, макс. 11 символов, согласовывается с Eskiz).
# Пока имя не подтверждено — используйте тестовый sender id "4546".
ESKIZ_SENDER_NAME=4546
